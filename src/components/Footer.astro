---
const today = new Date();
---

<footer>
	<div class="footer-links">
		<a href="https://www.linkedin.com/in/daanyaal-sobani/" target="_blank" rel="noopener">
			<span class="sr-only">LinkedIn</span>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
				<path
					fill="currentColor"
					d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
				></path>
			</svg>
		</a>
		<a href="https://x.com/daanyaalss" target="_blank" rel="noopener">
			<span class="sr-only">X (Twitter)</span>
			<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
				<path
					fill="currentColor"
					d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
				></path>
			</svg>
		</a>
	</div>
	<p class="copyright">&copy; {today.getFullYear()} Daanyaal Sobani</p>
	<p class="built-with">
		Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> &amp;
		<a href="https://workers.cloudflare.com" target="_blank" rel="noopener">Cloudflare Workers</a>
		&middot; Assembled with <a
			href="https://claude.ai/code"
			target="_blank"
			rel="noopener">Claude Code</a
		>
	</p>
</footer>
<style>
	footer {
		padding: 2em 1em 4em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 0.75em;
		margin-bottom: 0.75em;
	}
	.footer-links a {
		color: rgb(var(--gray));
		text-decoration: none;
		display: flex;
		align-items: center;
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.copyright {
		margin: 0 0 0.25em;
		font-size: 0.85em;
	}
	.built-with {
		margin: 0;
		font-size: 0.8em;
		color: rgb(var(--gray));
	}
	.built-with a {
		color: rgb(var(--gray));
		text-decoration: underline;
	}
	.built-with a:hover {
		color: var(--accent);
	}
</style>
